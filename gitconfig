[alias]
  git = !git #not complain about doubled git (git git clone ...)
  cc  = clone
  co  = checkout
  ci  = commit
  cia = commit -a -m
  b   = branch
  p   = push
  pom = push origin master
  ll = log --topo-order --decorate
  l   = log --pretty=oneline -n 20 --graph --abbrev-commit
  log = "log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit"
  tree = log --graph --decorate --pretty=oneline --abbrev-commit
  today = "log --since=midnight --oneline"
  s   = status --short --branch
  pul = pull --rebase
  unstage = "reset HEAD --"
  n = !"git ls-files | xargs notes | awk -F: '{ print $1,$2; print $3,$4; print $5}' | grcat conf.notes "
  committers = shortlog -nse --no-merges
  sync = !git pull origin master && git push origin master
  ignore = !git ls-files -v | grep "^[[:lower:]]"
  showlast = log -n 1 -p
  dif = diff --ignore-space-at-eol -b -w --ignore-blank-lines
  dc = diff --cached
  go = checkout -B

[apply]
  whitespace = fix

[color]
  diff = auto
  status = auto
  branch = auto
  ui = auto
[color "status"]
  added = green bold
  changed = yellow bold
  untracked = cyan bold
  branch = green bold
[color "branch"]
  current = green bold
  local = yellow
  remote = yellow
[color "diff"]
  meta = yellow bold
  frag = magenta bold
  old = red reverse
  new = green reverse
  whitespace = white reverse

[core]
  excludesfile = ~/.gitignore
  whitespace = space-before-tab,-indent-with-non-tab,trailing-space
  trustctime = false
  ignorecase = true
  logallrefupdates = true
  filemode = true
  quotepath = false
  autocrlf = input
  precomposeunicode = false
  untrackedCache = true

[push]
  default = current

[format]
  pretty = %C(cyan)%h%C(green) %an\t%Creset%s

[merge]
  log = true

[gpg]
  program = gpg1

[include]
  path = ~/.gitconfig.private
